# The build context is the repo root. Keep it small and never bake secrets or
# regenerable artifacts into the image.

# VCS / IDE / tooling
.git
.gitignore
.idea
.claude

# Docs and compose files (not needed inside the image)
*.md
docker-compose*.yml
.dockerignore

# Env files / secrets — provided at runtime, never baked in
.env
.env.*

# Craft dependencies & runtime artifacts (vendor is regenerated by the prod
# build via `composer install`; the rest is recreated at runtime)
craftcms/.env
craftcms/vendor
craftcms/storage/runtime
craftcms/storage/logs
craftcms/storage/backups
craftcms/web/cpresources

# Node / front-end build output
node_modules
craftcms/node_modules
craftcms/web/dist
craftcms/web/assets/build
