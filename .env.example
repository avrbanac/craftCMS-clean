# Copy to .env and adjust as needed:  cp .env.example .env
# docker compose reads this file automatically.

# --- Build args -------------------------------------------------------------
# PHP version installed in the craft image (via ppa:ondrej/php).
PHP_VERSION=8.4
# Must match your host user so bind-mounted files have a consistent owner.
# Check yours with:  id -u   and   id -g
HOST_UID=1000
HOST_GID=1000

# --- Ports (host side) ------------------------------------------------------
WEB_PORT=8080
DB_PORT=5432

# --- PostgreSQL / Craft DB connection --------------------------------------
POSTGRES_DB=craftcms
POSTGRES_USER=craftcms
# Fine for local dev. Use a STRONG, unique value for production.
POSTGRES_PASSWORD=secret

# --- Production only (docker-compose.prod.yml) ------------------------------
# Required by the prod stack. After running `php craft setup`, copy the
# CRAFT_SECURITY_KEY value that Craft wrote into craftcms/.env to here.
# CRAFT_SECURITY_KEY=
